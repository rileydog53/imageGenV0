{
  "meta": {
    "name": "nature",
    "description": "Bolder, geometric. Saturated 8-color qualitative palette derived from Paul Tol's colorblind-safe set. Thicker strokes, slightly larger labels."
  },
  "palette": [
    "#332288", "#117733", "#44AA99", "#88CCEE",
    "#DDCC77", "#CC6677", "#AA4499", "#882255"
  ],
  "overrides": {
    "label_font_family": "Helvetica, Arial, sans-serif",
    "label_font_size": 12,
    "label_font_color": "#0E1A2B",

    "protein_fill": "#88CCEE",
