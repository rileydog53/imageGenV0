    "receptor_fill": "#117733",
    "receptor_stroke": "#0A3D1A",

    "gpcr_helix_fill": "#AA4499",
    "gpcr_helix_stroke": "#5B1A4D",
    "gpcr_loop_stroke_width": 2.0,

    "tf_fill": "#CC6677",
