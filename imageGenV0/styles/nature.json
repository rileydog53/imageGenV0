    "tf_dbd_fill": "#5B1F2A",

    "stroke_width": 2.5,
    "arrow_head_size": 11,

    "chem_atom_C": "#0E1A2B",
    "chem_atom_N": "#332288",
    "chem_atom_O": "#882255",
    "chem_atom_P": "#CC6677",
